# Raw2Draft Environment Configuration
# Copy this file to ~/.raw2draft/.env and fill in the values you need.
# You can also configure these in the app via Settings.
#
# Lines starting with # are comments and will be ignored.

# ── AI Generation (at least one recommended) ─────────────────────────
# Used for AI-powered content generation features.
# You need at least one of these for AI generation to work.
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Transcription (optional) ─────────────────────────────────────────
# LemonFox: Used for audio transcription
LEMONFOX_API_KEY=

# AssemblyAI: Used for video transcription
ASSEMBLYAI_API_KEY=

# ── Image Hosting via AWS S3 (optional) ──────────────────────────────
# All four values are required if you want S3 image uploads.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# ── Social Media Scheduling (optional) ───────────────────────────────
# UploadPost: Used for scheduling social media posts
UPLOADPOST_API_KEY=
